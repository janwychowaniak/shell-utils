#!/usr/bin/env bash
# Pre-commit secret scan via gitleaks.
# Activated once with:  git config core.hooksPath .githooks
# Uses apt gitleaks 8.16 syntax (`protect --staged`); on 8.19+ `git --staged`
# is the modern spelling but `protect` still works as an alias.

command -v gitleaks >/dev/null 2>&1 || {
    echo "⚠️  gitleaks not installed — skipping secret scan (commit allowed)" >&2
    exit 0
}

if ! gitleaks protect --staged --redact -v; then
    echo "❌ gitleaks: potential secret in staged changes — commit blocked." >&2
    echo "   False positive? Add a regex/path to .gitleaks.toml -> [allowlist]." >&2
    exit 1
fi
